{
  "name": "pkg-name",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@11.0.8",
  "description": "TypeScript starter kit",
  "author": "ocavue <ocavue@gmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/ocavue/pkg-name#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ocavue/pkg-name.git"
  },
  "bugs": "https://github.com/ocavue/pkg-name/issues",
  "keywords": [],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "fix": "eslint --fix . && prettier --write .",
    "test": "vitest",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@ocavue/eslint-config": "^4.5.5",
    "@ocavue/tsconfig": "^0.7.1",
    "@types/node": "^22.19.11",
    "eslint": "^10.0.0",
    "prettier": "^3.0.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
