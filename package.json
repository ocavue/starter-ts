{
  "name": "@ocavue/starter-ts",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.5.0",
  "description": "TypeScript starter kit",
  "author": "ocavue <ocavue@gmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/ocavue/starter-ts#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ocavue/starter-ts.git"
  },
  "bugs": "https://github.com/ocavue/starter-ts/issues",
  "keywords": [],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "pnpm run lint:eslint && pnpm run lint:oxfmt && pnpm run lint:knip",
    "lint:oxfmt": "oxfmt --check",
    "lint:eslint": "eslint",
    "lint:knip": "knip",
    "fix": "pnpm run fix:oxfmt && pnpm run fix:eslint",
    "fix:oxfmt": "oxfmt",
    "fix:eslint": "eslint --fix",
    "test": "vitest",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@ocavue/eslint-config": "^4.5.9",
    "@ocavue/tsconfig": "^0.7.0",
    "@types/node": "^22.19.11",
    "eslint": "^10.4.1",
    "knip": "^6.15.0",
    "oxfmt": "^0.53.0",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
